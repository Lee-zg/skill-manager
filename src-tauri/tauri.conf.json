{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillManager",
  "version": "0.1.0",
  "identifier": "com.skillmanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkillManager",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": false,
        "transparent": false,
        "center": true,
        "resizable": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "SkillManager"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      },
      "wix": null
    },
    "macOS": {
      "dmg": {
        "background": null,
        "windowSize": { "width": 540, "height": 380 }
      },
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": true }
    },
    "resources": [],
    "copyright": "© 2026 SkillManager",
    "category": "DeveloperTool",
    "shortDescription": "AI Skills Management Tool",
    "longDescription": "SkillManager - A desktop tool for managing, discovering and installing AI coding skills across Claude Code, Agents and other tools."
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:skillmanager.db"]
    },
    "updater": {
      "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY_FROM_tauri_signer_generate",
      "endpoints": [
        "https://github.com/YOUR_USERNAME/skillmanager/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installerArgs": [],
        "installMode": "passive"
      }
    }
  }
}
